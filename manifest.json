{
  "manifest_version": 3,
  "name": "Idleon PiP",
  "version": "0.2.2",
  "description": "Open Legends of Idleon in Document Picture-in-Picture.",
  "author": "Rob Taylor <manix84@gmail.com>",
  "permissions": ["scripting", "activeTab"],
  "host_permissions": [
    "https://www.legendsofidleon.com/*",
    "https://*.legendsofidleon.com/*"
  ],
  "background": {
    "service_worker": "src/background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://www.legendsofidleon.com/*",
        "https://*.legendsofidleon.com/*"
      ],
      "js": ["src/content.js"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_title": "Toggle Idleon PiP",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
